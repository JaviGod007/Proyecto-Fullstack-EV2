  "methods": [
    {
      "name": "findByNombre",
      "signature": "public abstract java.util.List<com.Hotel.Hotel.model.Servicio> com.Hotel.Hotel.repository.ServicioRepository.findByNombre(java.lang.String)",
      "query": {
        "query": "SELECT s FROM Servicio s WHERE s.nombre = :nombre"
      }
    },
    {
      "name": "findByNombreContainingIgnoreCase",
      "signature": "public abstract java.util.List<com.Hotel.Hotel.model.Servicio> com.Hotel.Hotel.repository.ServicioRepository.findByNombreContainingIgnoreCase(java.lang.String)",
      "query": {
        "query": "SELECT s FROM Servicio s WHERE UPPER(s.nombre) LIKE UPPER(:nombre) ESCAPE '\\'"
      }
    },
    {
      "name": "findByPrecioBetween",
      "signature": "public abstract java.util.List<com.Hotel.Hotel.model.Servicio> com.Hotel.Hotel.repository.ServicioRepository.findByPrecioBetween(java.lang.Double,java.lang.Double)",
      "query": {
        "query": "SELECT s FROM Servicio s WHERE s.precio BETWEEN :precioMin AND :precioMax"
      }
    },
    {
      "name": "findByPrecioLessThanEqual",
      "signature": "public abstract java.util.List<com.Hotel.Hotel.model.Servicio> com.Hotel.Hotel.repository.ServicioRepository.findByPrecioLessThanEqual(java.lang.Double)",
      "query": {
        "query": "SELECT s FROM Servicio s WHERE s.precio <= :precio"
      }
    },
