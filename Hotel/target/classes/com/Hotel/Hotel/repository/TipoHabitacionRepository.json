    {
      "name": "findByNombre",
      "signature": "public abstract java.util.List<com.Hotel.Hotel.model.TipoHabitacion> com.Hotel.Hotel.repository.TipoHabitacionRepository.findByNombre(java.lang.String)",
      "query": {
        "query": "SELECT t FROM TipoHabitacion t WHERE t.nombre = :nombre"
      }
    },
    {
      "name": "findByNombreContainingIgnoreCase",
      "signature": "public abstract java.util.List<com.Hotel.Hotel.model.TipoHabitacion> com.Hotel.Hotel.repository.TipoHabitacionRepository.findByNombreContainingIgnoreCase(java.lang.String)",
      "query": {
        "query": "SELECT t FROM TipoHabitacion t WHERE UPPER(t.nombre) LIKE UPPER(:nombre) ESCAPE '\\'"
      }
    },
    {
      "name": "findByPrecio",
      "signature": "public abstract java.util.List<com.Hotel.Hotel.model.TipoHabitacion> com.Hotel.Hotel.repository.TipoHabitacionRepository.findByPrecio(java.lang.Integer)",
      "query": {
        "query": "SELECT t FROM TipoHabitacion t WHERE t.precio = :precio"
      }
